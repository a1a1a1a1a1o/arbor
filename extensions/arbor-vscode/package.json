{
  "name": "arbor-vscode",
  "displayName": "Arbor - Logic Forest",
  "description": "Connect VS Code to the Arbor Logic Forest for AI-aware code navigation",
  "version": "1.6.3",
  "publisher": "arbor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anandb71/arbor.git"
  },
  "bugs": {
    "url": "https://github.com/Anandb71/arbor/issues"
  },
  "homepage": "https://github.com/Anandb71/arbor",
  "keywords": [
    "arbor",
    "mcp",
    "code-graph",
    "refactor",
    "analysis"
  ],
    "engines": {
      "vscode": "^1.85.0"
    },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "files": [
    "out/**",
    "src/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "main": "./out/extension.js",
  "icon": "arbor-logo.png",
  "contributes": {
    "commands": [
      {
        "command": "arbor.showInVisualizer",
        "title": "Show in Arbor Visualizer"
      },
      {
        "command": "arbor.connect",
        "title": "Arbor: Connect to Server"
      },
      {
        "command": "arbor.toggleVisualizer",
        "title": "Arbor: Toggle Visualizer"
      }
    ],
    "keybindings": [
      {
        "command": "arbor.toggleVisualizer",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "arbor.showInVisualizer",
          "when": "editorTextFocus",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Arbor",
      "properties": {
        "arbor.serverUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:8080",
          "description": "WebSocket URL for the Arbor Sync Server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
